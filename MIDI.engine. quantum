import numpy as np

def generate_quantum_harmonic(base_freq, uncertainty=0.05):
    samples = 1000
    frequency_field = np.random.normal(base_freq, base_freq * uncertainty, samples)
    observed_frequency = np.mean(frequency_field)
    return observed_frequency

